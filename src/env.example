# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database Connection (if using local Supabase)
# POSTGRES_URL=postgresql://postgres:postgres@localhost:54322/postgres

# AI — Anthropic Claude (required for email generation, lead research, conversation analysis)
# Claude's built-in web_search tool is used for SMYKM lead research (no extra key needed)
# Get key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key

# AI (Novita) - Legacy, no longer used
# NOVITA_API_KEY=your-novita-api-key

# Lead Research — Perplexity (optional, legacy — no longer used)
# Research now uses Anthropic's native web_search tool instead
# PERPLEXITY_API_KEY=your-perplexity-api-key

# Gmail OAuth — for email sync + AI summaries
# Setup: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client
# Enable the Gmail API, add gmail.readonly scope, set redirect URI to /api/gmail/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# Optional: Application Settings
# SITE_URL=http://localhost:3000
# NODE_ENV=development
# NEXT_PUBLIC_APP_NAME=Rocoto
