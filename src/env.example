# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database Connection (if using local Supabase)
# POSTGRES_URL=postgresql://postgres:postgres@localhost:54322/postgres

# AI — Anthropic Claude (required for SMYKM email generation)
# Get key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key

# AI (Novita) - Legacy, used for contact insights and deal scoring
NOVITA_API_KEY=your-novita-api-key
# NOVITA_MODEL=meta-llama/llama-3.3-70b-instruct

# Lead Research — Perplexity Sonar adds live web search for SMYKM research.
# Falls back to Anthropic if not set.
# Get key at https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your-perplexity-api-key

# Gmail OAuth — for email sync + AI summaries
# Setup: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client
# Enable the Gmail API, add gmail.readonly scope, set redirect URI to /api/gmail/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# Optional: Application Settings
# SITE_URL=http://localhost:3000
# NODE_ENV=development
# NEXT_PUBLIC_APP_NAME=Rocoto
